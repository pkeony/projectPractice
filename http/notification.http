
@baseUrl = http://localhost:3001

### 🔑 BUYER 로그인
# @name loginBuyer1
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "buyer1@test.com",
  "password": "password123"
}

### 🔑 SELLER 로그인
# @name loginSeller1
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "seller1@test.com",
  "password": "password123"
}

